# Banco de dados (PostgreSQL - ex: Neon, Supabase ou local)
DATABASE_URL="postgresql://user:password@localhost:5432/radarauto"

# Ambiente recomendado:
# Use Node.js 18 ou 20 LTS. Node 23/24 pode causar comportamento instavel com Next.js 14.

# OpenAI - para analise de anuncios com IA
OPENAI_API_KEY="sk-proj-..."

# Segredo JWT/autenticacao
NEXTAUTH_SECRET="troque-por-uma-chave-longa-com-32-ou-mais-caracteres"

# AbacatePay - checkout de assinatura e cobrancas recorrentes
ABACATEPAY_API_KEY=""
ABACATEPAY_WEBHOOK_SECRET=""
ABACATEPAY_PRODUCT_BASICO_ID=""
ABACATEPAY_PRODUCT_PRO_ID=""
ABACATEPAY_PRODUCT_AGENCIA_ID=""

# Telegram Bot - para alertas automaticos
TELEGRAM_BOT_TOKEN="123456:ABC..."
TELEGRAM_CHAT_ID="-100123456789"

# WhatsApp Business API (Meta) - opcional fase 2
WHATSAPP_TOKEN=""
WHATSAPP_PHONE_ID=""

# API FIPE gratuita
FIPE_API_URL="https://parallelum.com.br/fipe/api/v1"

# Laudo veicular - opcional para integrar provedor externo
VEHICLE_REPORT_PROVIDER="placasapp"
VEHICLE_REPORT_API_URL="https://api.consultarplaca.com.br/v2/solicitarRelatorio"
VEHICLE_REPORT_API_KEY=""
VEHICLE_REPORT_BASIC_USER=""
VEHICLE_REPORT_API_EMAIL=""
VEHICLE_REPORT_PROVIDER_NAME="placas.app.br"
VEHICLE_REPORT_AUTH_HEADER="Authorization"
VEHICLE_REPORT_AUTH_PREFIX="Bearer"
VEHICLE_REPORT_TIMEOUT_MS="15000"
VEHICLE_REPORT_POLL_ATTEMPTS="8"
VEHICLE_REPORT_POLL_INTERVAL_MS="1500"
VEHICLE_REPORT_CONSULTAR_PLACA_STATUS_URL="https://api.consultarplaca.com.br/v2/consultarProtocolo"
VEHICLE_REPORT_CONSULTAR_PLACA_TIPO="prata"
VEHICLE_REPORT_CONSULTAR_PLACA_INFO=""
VEHICLE_REPORT_CONSULTAR_PLACA_REVENDA="false"
VEHICLE_REPORT_REQUIRED="false"

# Laudo veicular - alternativa por placas.app.br
# Quando usar este provedor, troque VEHICLE_REPORT_PROVIDER para "placasapp"
VEHICLE_REPORT_PLACAS_APP_BASE_URL="https://placas.app.br/api/v1"
VEHICLE_REPORT_PLACAS_APP_EMAIL=""
VEHICLE_REPORT_PLACAS_APP_PASSWORD=""

# URL do sistema
NEXT_PUBLIC_APP_URL="http://localhost:3000"
