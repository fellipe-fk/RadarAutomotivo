# Banco de dados (PostgreSQL - ex: Neon, Supabase ou local)
DATABASE_URL="postgresql://user:password@localhost:5432/radarauto"

# Ambiente recomendado:
# Use Node.js 18 ou 20 LTS. Node 23/24 pode causar comportamento instavel com Next.js 14.

# OpenAI - para analise de anuncios com IA
OPENAI_API_KEY="sk-proj-..."

# Segredo JWT/autenticacao
NEXTAUTH_SECRET="troque-por-uma-chave-longa-com-32-ou-mais-caracteres"

# Asaas - opcional para onboarding e pagamentos
ASAAS_API_KEY=""

# Telegram Bot - para alertas automaticos
TELEGRAM_BOT_TOKEN="123456:ABC..."
TELEGRAM_CHAT_ID="-100123456789"

# WhatsApp Business API (Meta) - opcional fase 2
WHATSAPP_TOKEN=""
WHATSAPP_PHONE_ID=""

# API FIPE gratuita
FIPE_API_URL="https://parallelum.com.br/fipe/api/v1"

# URL do sistema
NEXT_PUBLIC_APP_URL="http://localhost:3000"
